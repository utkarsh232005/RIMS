# Multi-Model LLM Configuration (Gemini + OpenAI)
# The backend tries Gemini first, then falls back to OpenAI.
# You need at least ONE key configured for the AI assistant to work.

# Get your Gemini API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Model name (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Get your OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
# Model name (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# FastAPI Configuration
HOST=127.0.0.1
PORT=8000
RELOAD=True

# Pinecone Vector Database Configuration
# Get your API key from: https://app.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=your_index_name_here
PINECONE_NAMESPACE=
# Embedding model (must match what you used to create embeddings)
PINECONE_EMBEDDING_MODEL=all-MiniLM-L6-v2
# Metadata field that holds the chunk text
PINECONE_TEXT_FIELD=text
# Host can be copied from the Databricks workspace URL without https://
DATABRICKS_SERVER_HOSTNAME=adb-xxxxxxxxxxxxxxxx.x.azuredatabricks.net
# Use either the SQL warehouse HTTP path or the warehouse ID.
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id
# DATABRICKS_WAREHOUSE_ID=your_warehouse_id
DATABRICKS_ACCESS_TOKEN=dapi_your_databricks_pat_here
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=default
DATABRICKS_CACHE_TTL_SECONDS=300
